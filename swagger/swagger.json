{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoList API",
    "version": "1.1.0",
    "description": "TodoList 애플리케이션 REST API 명세서입니다.\n\n이 문서는 `swagger/swagger.json`, `swagger/swagger_claude.json`, 그리고 `docs/` 하위 요구사항 문서를 함께 대조해 재정리한 통합 스펙입니다.\n\n## 인증\n- 보호된 엔드포인트는 `Authorization: Bearer <token>` 헤더를 사용합니다.\n- JWT 서명 알고리즘은 `HS-512` 입니다.\n\n## 공통 응답 포맷\n- 성공: `{ \"success\": true, \"data\": ... }`\n- 목록 성공: `{ \"success\": true, \"data\": [...], \"pagination\": { ... } }`\n- 에러: `{ \"success\": false, \"error\": { \"code\": \"ERROR_CODE\", \"message\": \"설명\" } }`\n\n## 정리 기준\n- 엔드포인트 집합은 `docs/4-architecture-principles.md`, `docs/7-execution-plan.md` 기준으로 확정했습니다.\n- 회원 탈퇴 시 현재 비밀번호 확인 요구는 `docs/3-user-scenario.md`를 반영해 요청 본문에 포함했습니다.\n- 할일 상태(`status`, `is_overdue`, `is_due_soon`)는 문서상의 도메인 규칙을 반영한 응답 전용 계산 필드입니다.",
    "contact": {
      "email": "ahgns1515@naver.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "로컬 개발 서버"
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "서버 상태 확인 엔드포인트"
    },
    {
      "name": "Auth",
      "description": "회원가입, 로그인, 회원탈퇴 등 인증 관련 엔드포인트"
    },
    {
      "name": "Categories",
      "description": "카테고리 생성, 조회, 수정, 삭제 엔드포인트"
    },
    {
      "name": "Todos",
      "description": "할일 CRUD, 상태 전환, 필터링 조회 엔드포인트"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "로그인 성공 시 발급되는 JWT Bearer 토큰입니다."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "description": "사용자 계정 정보 (응답 전용)",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T09:00:00.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "created_at"
        ]
      },
      "Category": {
        "type": "object",
        "description": "사용자 소유 카테고리",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "example": "업무"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T09:00:00.000Z"
          }
        },
        "required": [
          "id",
          "user_id",
          "name",
          "created_at"
        ]
      },
      "Todo": {
        "type": "object",
        "description": "할일 항목. `status`, `is_overdue`, `is_due_soon`은 응답 전용 계산 필드입니다.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "c3d4e5f6-a7b8-9012-cdef-123456789012"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          "title": {
            "type": "string",
            "maxLength": 255,
            "example": "OpenAPI 스펙 작성하기"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "swagger_codex.json 파일로 저장할 것"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-04-30T18:00:00.000Z"
          },
          "is_completed": {
            "type": "boolean",
            "example": false
          },
          "status": {
            "type": "string",
            "readOnly": true,
            "enum": [
              "in_progress",
              "completed",
              "overdue"
            ],
            "example": "in_progress"
          },
          "is_overdue": {
            "type": "boolean",
            "readOnly": true,
            "description": "완료된 항목은 항상 false 입니다.",
            "example": false
          },
          "is_due_soon": {
            "type": "boolean",
            "readOnly": true,
            "description": "현재 시각 기준 24시간 이내 마감 예정 여부입니다.",
            "example": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T09:00:00.000Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T12:30:00.000Z"
          }
        },
        "required": [
          "id",
          "user_id",
          "category_id",
          "title",
          "description",
          "due_date",
          "is_completed",
          "status",
          "is_overdue",
          "is_due_soon",
          "created_at",
          "updated_at"
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 8,
            "example": "P@ssw0rd123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "P@ssw0rd123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "DeleteAccountRequest": {
        "type": "object",
        "description": "회원 탈퇴 전 본인 확인용 현재 비밀번호",
        "properties": {
          "password": {
            "type": "string",
            "format": "password",
            "example": "P@ssw0rd123"
          }
        },
        "required": [
          "password"
        ]
      },
      "LoginResponseData": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImExYjJjM2Q0LWU1ZjYtNzg5MC1hYmNkLWVmMTIzNDU2Nzg5MCIsImVtYWlsIjoidXNlckBleGFtcGxlLmNvbSIsImlhdCI6MTc0NTg0MDAwMCwiZXhwIjoxNzQ1ODQzNjAwfQ.signature"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        },
        "required": [
          "token",
          "user"
        ]
      },
      "CategoryRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "example": "개인"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateTodoRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 255,
            "example": "프로젝트 회고 작성"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "배운 점 3가지를 정리한다"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-04-30T18:00:00.000Z"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateTodoRequest": {
        "type": "object",
        "description": "전달한 필드만 갱신됩니다. null 전달 시 선택 필드를 해제할 수 있습니다.",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 255,
            "example": "프로젝트 회고 최종 정리"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "최종 피드백까지 반영한다"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-05-01T12:00:00.000Z"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "example": null
          }
        }
      },
      "MessageData": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "삭제 완료"
          }
        },
        "required": [
          "message"
        ]
      },
      "HealthData": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          }
        },
        "required": [
          "status"
        ]
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "example": 20
          },
          "total": {
            "type": "integer",
            "minimum": 0,
            "example": 53
          }
        },
        "required": [
          "page",
          "limit",
          "total"
        ]
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string",
            "example": "요청 데이터가 유효하지 않습니다."
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ],
            "example": false
          },
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "required": [
          "success",
          "error"
        ]
      }
    },
    "responses": {
      "ValidationError": {
        "description": "요청 데이터 유효성 검사 실패",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "code": "VALIDATION_ERROR",
                "message": "요청 데이터가 유효하지 않습니다."
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "인증 실패 또는 토큰 누락",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "code": "UNAUTHORIZED",
                "message": "인증이 필요합니다."
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "타인 리소스 접근 차단",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "code": "FORBIDDEN",
                "message": "본인의 리소스에만 접근할 수 있습니다."
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "리소스를 찾을 수 없음",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "code": "NOT_FOUND",
                "message": "요청한 리소스를 찾을 수 없습니다."
              }
            }
          }
        }
      },
      "InternalServerError": {
        "description": "서버 내부 오류",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "code": "INTERNAL_SERVER_ERROR",
                "message": "서버 내부 오류가 발생했습니다."
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "헬스체크",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "서버와 DB 연결 상태가 정상입니다.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    },
                    "data": {
                      "$ref": "#/components/schemas/HealthData"
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "status": "ok"
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "회원가입",
        "description": "이메일과 비밀번호로 새 계정을 생성합니다.",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    },
                    "data": {
                      "$ref": "#/components/schemas/User"
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "409": {
            "description": "이미 사용 중인 이메일",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "DUPLICATE_EMAIL",
                    "message": "이미 사용 중인 이메일 주소입니다."
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "로그인",
        "description": "이메일과 비밀번호를 검증하고 JWT Bearer 토큰을 발급합니다.",
        "operationId": "loginUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    },
                    "data": {
                      "$ref": "#/components/schemas/LoginResponseData"
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "description": "이메일 또는 비밀번호 불일치",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INVALID_CREDENTIALS",
                    "message": "이메일 또는 비밀번호가 올바르지 않습니다."
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "delete": {
        "tags": [
          "Auth"
        ],
        "summary": "회원탈퇴",
        "description": "현재 인증된 사용자의 계정과 하위 데이터를 즉시 삭제합니다. 사용자 시나리오 문서 기준으로 현재 비밀번호 확인을 요청 본문에 포함합니다.",
        "operationId": "deleteCurrentUser",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteAccountRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "회원탈퇴 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    },
                    "data": {
                      "$ref": "#/components/schemas/MessageData"
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "message": "탈퇴가 완료되었습니다."
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "description": "현재 비밀번호 불일치",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INVALID_PASSWORD",
                    "message": "비밀번호가 올바르지 않습니다."
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "tags": [
          "Categories"
        ],
        "summary": "카테고리 목록 조회",
        "operationId": "getCategories",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "카테고리 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Category"
                      }
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                }
              }
            }
